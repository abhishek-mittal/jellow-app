# Jellow App Environment Variables

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jellow

# ─── Auth (Better Auth) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=       # Generate with: openssl rand -base64 32

# Google OAuth (optional — omit to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (optional — omit to disable)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Food Database API ──────────────────────────────────────────────────────
FOOD_API_URL=

# ─── Analytics ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ID=

# ─── PWA ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
